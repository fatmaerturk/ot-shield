# CRA 5: DO NOT set HOST here while using dev proxy — breaks webpack-dev-server allowedHosts.
# Backend URL for src/setupProxy.js (optional):
# REACT_APP_BACKEND_URL=http://localhost:8080

# --- allowedHosts fix ---------------------------------------------------
# When setupProxy.js is used, react-scripts enables the firewall and passes
# [allowedHost] to webpack-dev-server. If the machine has no private LAN IP
# (common on dev laptops with only a VPN interface), allowedHost resolves to
# `undefined` and webpack-dev-server 4 throws:
#     "options.allowedHosts[0] should be a non-empty string."
# Disabling the host check makes react-scripts pass allowedHosts: 'all',
# which is safe in local dev because we only bind to localhost.
DANGEROUSLY_DISABLE_HOST_CHECK=true
