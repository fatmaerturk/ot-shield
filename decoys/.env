# Copy this file to .env and fill in the real values.
#
# Where the OTShield backend lives. From inside the docker-compose network the
# host machine is reachable via host.docker.internal, so for local dev you can
# typically use:
#   INGEST_URL=http://host.docker.internal:8080
#
# If you've already set up a Cloudflare Tunnel (see backend/geoip/README.md
# for the wider setup), point at that hostname instead so the decoys can be
# moved to a different machine without reconfiguring.
INGEST_URL=http://host.docker.internal:8080

# The Bearer token the backend expects on /api/honeypot/ingest. Must match
# `honeypot.ingest.token` in backend/src/main/resources/application.properties.
INGEST_TOKEN=GcZ9KY7ANmLfvob6SOWxnRBjVlEPX2uaMr805td4IHTCezyU
